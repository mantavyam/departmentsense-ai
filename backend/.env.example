# Backend config
APP_ENV=dev
DATABASE_URL=sqlite+aiosqlite:///./departmentsense.db
SECRET_KEY=change-me-in-prod-please

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# HuggingFace classification (optional; falls back to keyword classifier)
# Get a free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_CLASSIFIER_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
HF_SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# Use local transformers pipeline (downloads model on first run, ~1.5GB)
USE_LOCAL_ML=false
