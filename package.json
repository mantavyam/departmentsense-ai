{
  "name": "departmentsense-ai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"web,api\" -c \"green,blue\" \"pnpm run dev:web\" \"pnpm run dev:api\"",
    "dev:web": "turbo dev",
    "dev:api": "cd backend && uv run uvicorn app.main:app --port 8000 --reload",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "setup:api": "cd backend && uv sync && cp -n .env.example .env || true",
    "test:e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
